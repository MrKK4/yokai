<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@+id/checked" android:drawable="@drawable/ic_suggestions_filled_24dp" android:state_checked="true" />
    <item android:id="@+id/normal" android:drawable="@drawable/ic_suggestions_outline_24dp" android:state_checked="false" />
    <transition android:fromId="@+id/normal" android:toId="@+id/checked" android:drawable="@anim/anim_suggestions_outline_to_filled" />
    <transition android:fromId="@+id/checked" android:toId="@+id/normal" android:drawable="@anim/anim_suggestions_filled_to_outline" />
</animated-selector>